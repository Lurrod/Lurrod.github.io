<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Force le slash final sur /en
    RewriteRule ^en$ /en/ [R=301,L]

    # Redirections 301 permanentes (suppression du .html)
    RewriteRule ^index\.html$ / [R=301,L]
    RewriteRule ^en/index\.html$ /en/ [R=301,L]

    # Réécriture interne propre (sans que l'utilisateur voie le .html)
    # Racine /
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^$ index.html [L]

    # Dossier /en/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^en/?$ en/index.html [L]
</IfModule>